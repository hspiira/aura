# Application
APP_NAME=aura
APP_VERSION=0.1.0
ENV=development
DEBUG=false

# Database (required for Phase 1+ API: org, departments, roles, users, cycles, dimensions)
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/aura

# Optional: seed an Admin user with all permissions and a login token:
